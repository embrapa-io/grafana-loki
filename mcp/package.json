{
    "name": "@embrapa-io/mcp-loki",
    "private": true,
    "version": "0.1.0",
    "description": "Embrapa I/O MCP Server — Consulta de logs do Grafana Loki",
    "license": "UNLICENSED",
    "author": "Embrapa I/O",
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@10.26.1",
    "scripts": {
        "dev": "tsx watch --clear-screen=false src/index.ts",
        "build": "tsdown",
        "start": "node dist/index.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "build:packages": "pnpm -r --filter './packages/**' build",
        "typecheck:all": "pnpm -r typecheck"
    },
    "dependencies": {
        "@modelcontextprotocol/server": "workspace:^",
        "@modelcontextprotocol/node": "workspace:^",
        "@modelcontextprotocol/express": "workspace:^",
        "better-sqlite3": "^11.10.0",
        "cors": "catalog:runtimeServerOnly",
        "express": "catalog:runtimeServerOnly",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.1.0",
        "hono": "catalog:runtimeServerOnly",
        "@hono/node-server": "catalog:runtimeServerOnly",
        "ioredis": "^5.6.1",
        "jose": "catalog:runtimeClientOnly",
        "pino": "^9.6.0",
        "pino-pretty": "^13.0.0",
        "zod": "catalog:runtimeShared"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "catalog:devTools",
        "@types/express": "catalog:devTools",
        "@types/node": "^24.10.1",
        "tsdown": "catalog:devTools",
        "tsx": "catalog:devTools",
        "typescript": "catalog:devTools",
        "vitest": "catalog:devTools"
    },
    "resolutions": {
        "strip-ansi": "6.0.1"
    }
}
